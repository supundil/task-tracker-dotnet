        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Task created successfully\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const body = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"taskId\", body.id);\r",
                  "\r",
                  "console.log(\"Task ID Saved:\", body.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
